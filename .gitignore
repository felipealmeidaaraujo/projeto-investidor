# Dependências
node_modules/
dist/
.cache/

# Segredos (NUNCA versionar chaves de API)
.env
.env.*
!.env.example

# Dados brutos baixados (grandes / não versionar)
data/*
!data/.gitkeep
# Exceção: pico de ranking 2010-2019 é dado DERIVADO, pequeno (238 KB) e imutável
# (essa história não muda mais). Versionado de propósito: evita rebaixar 37 MB/dia
# no cron só para recalcular um número congelado desde 2019. Gerado por
# pipeline/peak-cache-build.js, que roda uma vez e NÃO entra no cron.
!data/peak-2010-2019.json

# Sistema
*.log
.DS_Store
Thumbs.db

# Mockups do companion de brainstorming (efêmeros)
.superpowers/

# Screenshots de auditoria/design (efêmeros)
audit-*.png
ds*.png
.playwright-mcp/

# Guia de estilo vivo — ferramenta de trabalho local (localhost:5173/design-system.html).
# Fica fora do repo porque o deploy publica a pasta web/ inteira: se versionado,
# iria pro ar no site público.
web/design-system.html
